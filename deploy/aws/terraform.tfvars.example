project_name = "halligalli"
aws_region   = "eu-west-1"

domain_name       = "example.com"
frontend_subdomain = "play"
backend_subdomain  = "api"
route53_zone_id     = "Z0123456789EXAMPLE"

frontend_cloudfront_enabled = false

backend_certificate_arn = "arn:aws:acm:eu-west-1:123456789012:certificate/00000000-0000-0000-0000-000000000000"
backend_image_tag       = "aws-production-scaffold-placeholder"
backend_desired_count   = 0
backend_task_cpu        = 256
backend_task_memory     = 512
backend_app_version     = "aws-production-scaffold-placeholder"
backend_commit_sha      = "0000000000000000000000000000000000000000"

github_repository    = "example-owner/example-repo"
github_oidc_subjects = ["repo:example-owner/example-repo:environment:aws-production-scaffold"]

# Leave null to let Terraform create the account's GitHub Actions OIDC provider.
github_oidc_provider_arn = null
