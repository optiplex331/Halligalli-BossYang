{
	"name": "halligalli-arena",
	"private": true,
	"description": "A real-time multiplayer Halligalli table for exact-five card races, solo practice, and server-authoritative rooms.",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/optiplex331/Halligalli-BossYang.git"
	},
	"homepage": "https://play.halligalli.games",
	"bugs": {
		"url": "https://github.com/optiplex331/Halligalli-BossYang/issues"
	},
	"keywords": [
		"halligalli",
		"multiplayer",
		"browser-game",
		"reaction-trainer",
		"socket.io",
		"react",
		"vite",
		"typescript"
	],
	"packageManager": "pnpm@11.0.9",
	"type": "module",
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=24.0.0 <25"
		}
	},
	"scripts": {
		"dev": "vite",
		"dev:server": "tsx server/index.ts",
		"build": "vite build && tsc -p tsconfig.server.json",
		"start": "node dist/server/index.js",
		"preview": "vite preview",
		"test": "vitest run",
		"typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
		"simulate:bell": "tsx scripts/simulate-bell.ts"
	},
	"engines": {
		"node": ">=24.0.0 <25",
		"pnpm": ">=11.0.9"
	},
	"dependencies": {
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"socket.io": "^4.8.0",
		"socket.io-client": "^4.8.3"
	},
	"devDependencies": {
		"@types/node": "^24.13.1",
		"@types/react": "^19.2.16",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.2",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	}
}
